{
  "__inputs": [{ "name": "DS_BINARYLANE", "label": "BinaryLane", "type": "datasource", "pluginId": "yesoreyeram-infinity-datasource" }],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "yesoreyeram-infinity-datasource", "name": "Infinity", "version": "2.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "text", "name": "Text", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "BinaryLane account billing — current balance, unbilled charges, invoice history, failed payment alerts.",
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "links": [{ "title": "BinaryLane Billing", "type": "link", "url": "https://home.binarylane.com.au/billing", "targetBlank": true, "icon": "external link" }],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100, "title": "💳 Account Status", "type": "row"
    },
    {
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
      "description": "Account status. Warning or Locked states require immediate attention — contact BinaryLane support.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" }, "unit": "string",
          "mappings": [
            { "type": "value", "options": { "active": { "color": "green", "index": 0, "text": "● Active" } } },
            { "type": "value", "options": { "incomplete": { "color": "yellow", "index": 1, "text": "◐ Incomplete" } } },
            { "type": "value", "options": { "warning": { "color": "orange", "index": 2, "text": "⚠ Warning" } } },
            { "type": "value", "options": { "locked": { "color": "red", "index": 3, "text": "✕ Locked" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 5, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^status$/", "values": false }, "textMode": "auto" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
        "type": "json", "source": "url", "format": "table",
        "url": "https://api.binarylane.com.au/v2/account",
        "root_selector": "account",
        "json_options": { "root_is_not_array": true, "columnar": false },
        "columns": [
          { "selector": "status", "text": "status", "type": "string" },
          { "selector": "email", "text": "email", "type": "string" },
          { "selector": "email_verified", "text": "email_verified", "type": "boolean" },
          { "selector": "two_factor_authentication_enabled", "text": "2fa", "type": "boolean" },
          { "selector": "additional_ipv4_limit", "text": "ipv4_limit", "type": "number" }
        ],
        "url_options": { "method": "GET", "data": "" }, "parser": "backend", "filters": []
      }],
      "title": "Account Status",
      "type": "stat"
    },
    {
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
      "description": "Whether two-factor authentication is enabled on this account.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" }, "unit": "string",
          "mappings": [
            { "type": "value", "options": { "true": { "color": "green", "index": 0, "text": "✓ 2FA Enabled" } } },
            { "type": "value", "options": { "false": { "color": "red", "index": 1, "text": "✕ 2FA Disabled" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 5, "x": 5, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^2fa$/", "values": false }, "textMode": "auto" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
        "type": "json", "source": "url", "format": "table",
        "url": "https://api.binarylane.com.au/v2/account",
        "root_selector": "account",
        "json_options": { "root_is_not_array": true, "columnar": false },
        "columns": [{ "selector": "two_factor_authentication_enabled", "text": "2fa", "type": "boolean" }],
        "url_options": { "method": "GET", "data": "" }, "parser": "backend", "filters": []
      }],
      "title": "Two-Factor Auth",
      "type": "stat"
    },
    {
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
      "description": "Available credit on account in AU$.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" }, "unit": "currencyAUD", "decimals": 2,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "text", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "gridPos": { "h": 4, "w": 5, "x": 10, "y": 1 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^Available Credit$/", "values": false }, "textMode": "auto" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
        "type": "json", "source": "url", "format": "table",
        "url": "https://api.binarylane.com.au/v2/customers/my/balance",
        "root_selector": "balance",
        "json_options": { "root_is_not_array": true, "columnar": false },
        "columns": [
          { "selector": "available_credit", "text": "Available Credit", "type": "number" },
          { "selector": "unbilled_total", "text": "Unbilled Total", "type": "number" }
        ],
        "url_options": { "method": "GET", "data": "" }, "parser": "backend", "filters": []
      }],
      "title": "Available Credit",
      "type": "stat"
    },
    {
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
      "description": "Total unbilled charges accrued so far this billing period in AU$.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" }, "unit": "currencyAUD", "decimals": 2,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "text", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 200 }] }
        }
      },
      "gridPos": { "h": 4, "w": 5, "x": 15, "y": 1 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^Unbilled Total$/", "values": false }, "textMode": "auto" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
        "type": "json", "source": "url", "format": "table",
        "url": "https://api.binarylane.com.au/v2/customers/my/balance",
        "root_selector": "balance",
        "json_options": { "root_is_not_array": true, "columnar": false },
        "columns": [{ "selector": "unbilled_total", "text": "Unbilled Total", "type": "number" }],
        "url_options": { "method": "GET", "data": "" }, "parser": "backend", "filters": []
      }],
      "title": "Unbilled Total (AU$)",
      "type": "stat"
    },
    {
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
      "description": "Invoices with failed payment attempts that are still unpaid. These may block new services or renewals.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" }, "unit": "short", "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] },
          "noValue": "0"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 5,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto",
        "reduceOptions": { "calcs": ["count"], "fields": "/^invoice_id$/", "values": false }, "textMode": "value_and_name" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
        "type": "json", "source": "url", "format": "table",
        "url": "https://api.binarylane.com.au/v2/customers/my/unpaid-payment-failed-invoices",
        "root_selector": "invoices",
        "columns": [{ "selector": "invoice_id", "text": "invoice_id", "type": "number" }],
        "url_options": { "method": "GET", "data": "" }, "parser": "backend", "filters": []
      }],
      "title": "Failed Invoices",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101, "title": "💸 Current Unbilled Charges", "type": "row"
    },
    {
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
      "description": "Individual charges contributing to the unbilled total. 'Ongoing' = active running service. 'Pending' = completed, awaiting invoice.",
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "filterable": true } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Total AU$" }, "properties": [
            { "id": "unit", "value": "currencyAUD" }, { "id": "decimals", "value": 4 },
            { "id": "custom.width", "value": 100 }
          ]},
          { "matcher": { "id": "byName", "options": "Created" }, "properties": [
            { "id": "unit", "value": "dateTimeAsLocal" }, { "id": "custom.width", "value": 180 }
          ]},
          { "matcher": { "id": "byName", "options": "Type" }, "properties": [
            { "id": "mappings", "value": [
              { "type": "value", "options": { "true": { "color": "blue", "index": 0, "text": "Ongoing" } } },
              { "type": "value", "options": { "false": { "color": "yellow", "index": 1, "text": "Pending Invoice" } } }
            ]},
            { "id": "custom.cellOptions", "value": { "type": "color-background" } },
            { "id": "custom.width", "value": 140 }
          ]}
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 6 },
      "id": 6,
      "options": { "cellHeight": "sm", "footer": {
        "show": true, "reducer": ["sum"], "fields": ["Total AU$"], "enablePagination": false, "countRows": false
      }, "showHeader": true, "sortBy": [{ "desc": true, "displayName": "Total AU$" }] },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
        "type": "json", "source": "url", "format": "table",
        "url": "https://api.binarylane.com.au/v2/customers/my/balance",
        "root_selector": "balance.charges",
        "columns": [
          { "selector": "description", "text": "Description", "type": "string" },
          { "selector": "total", "text": "Total AU$", "type": "number" },
          { "selector": "ongoing", "text": "Type", "type": "boolean" },
          { "selector": "created", "text": "Created", "type": "timestamp" }
        ],
        "url_options": { "method": "GET", "data": "" }, "parser": "backend", "filters": []
      }],
      "title": "Unbilled Charges Breakdown",
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 102, "title": "🧾 Invoice History", "type": "row"
    },
    {
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
      "description": "Invoice history. PDF download links expire 24 hours after the API response is generated.",
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "filterable": true } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Amount AU$" }, "properties": [{ "id": "unit", "value": "currencyAUD" }, { "id": "decimals", "value": 2 }, { "id": "custom.width", "value": 110 }] },
          { "matcher": { "id": "byName", "options": "Tax AU$" }, "properties": [{ "id": "unit", "value": "currencyAUD" }, { "id": "decimals", "value": 2 }, { "id": "custom.width", "value": 90 }] },
          { "matcher": { "id": "byName", "options": "Created" }, "properties": [{ "id": "unit", "value": "dateTimeAsLocal" }, { "id": "custom.width", "value": 180 }] },
          { "matcher": { "id": "byName", "options": "Due" }, "properties": [{ "id": "unit", "value": "dateTimeAsLocal" }, { "id": "custom.width", "value": 180 }] },
          { "matcher": { "id": "byName", "options": "Paid" }, "properties": [
            { "id": "mappings", "value": [
              { "type": "value", "options": { "true": { "color": "green", "index": 0, "text": "✓ Paid" } } },
              { "type": "value", "options": { "false": { "color": "red", "index": 1, "text": "✕ Unpaid" } } }
            ]},
            { "id": "custom.cellOptions", "value": { "type": "color-background" } },
            { "id": "custom.width", "value": 90 }
          ]},
          { "matcher": { "id": "byName", "options": "Failures" }, "properties": [
            { "id": "custom.width", "value": 80 },
            { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "text", "value": null }, { "color": "red", "value": 1 }] } },
            { "id": "custom.cellOptions", "value": { "type": "color-background", "applyToRow": false } }
          ]},
          { "matcher": { "id": "byName", "options": "PDF" }, "properties": [
            { "id": "custom.cellOptions", "value": { "type": "json-view" } }
          ]}
        ]
      },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 17 },
      "id": 7,
      "options": { "cellHeight": "sm", "footer": {
        "show": true, "reducer": ["sum"], "fields": ["Amount AU$", "Tax AU$"], "enablePagination": true, "countRows": false
      }, "showHeader": true, "sortBy": [{ "desc": true, "displayName": "Created" }] },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
        "type": "json", "source": "url", "format": "table",
        "url": "https://api.binarylane.com.au/v2/customers/my/invoices?per_page=200",
        "root_selector": "invoices",
        "columns": [
          { "selector": "invoice_number", "text": "Invoice #", "type": "string" },
          { "selector": "reference", "text": "Reference", "type": "string" },
          { "selector": "amount", "text": "Amount AU$", "type": "number" },
          { "selector": "tax", "text": "Tax AU$", "type": "number" },
          { "selector": "paid", "text": "Paid", "type": "boolean" },
          { "selector": "refunded", "text": "Refunded", "type": "boolean" },
          { "selector": "payment_failure_count", "text": "Failures", "type": "number" },
          { "selector": "created", "text": "Created", "type": "timestamp" },
          { "selector": "date_due", "text": "Due", "type": "timestamp" },
          { "selector": "invoice_download_url", "text": "PDF", "type": "string" }
        ],
        "url_options": { "method": "GET", "data": "" }, "parser": "backend", "filters": []
      }],
      "title": "Invoice History",
      "type": "table"
    }
  ],
  "refresh": "10m",
  "schemaVersion": 39,
  "tags": ["binarylane", "billing", "account"],
  "templating": {
    "list": [{
      "current": {}, "hide": 0, "includeAll": false, "label": "Datasource", "multi": false,
      "name": "DS_BINARYLANE", "query": "yesoreyeram-infinity-datasource", "refresh": 1, "type": "datasource"
    }]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "title": "BinaryLane — Billing & Account",
  "uid": "bl-billing",
  "version": 1
}
