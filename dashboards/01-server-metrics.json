{
  "__inputs": [{ "name": "DS_BINARYLANE", "label": "BinaryLane", "type": "datasource", "pluginId": "yesoreyeram-infinity-datasource" }],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "yesoreyeram-infinity-datasource", "name": "Infinity", "version": "2.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "BinaryLane server performance — CPU, memory, network I/O, storage I/O, data transfer. Requires mPanel Memory Graph agent for memory metrics.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [{ "title": "BinaryLane mPanel", "type": "link", "url": "https://home.binarylane.com.au", "targetBlank": true, "icon": "external link" }],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "⚡ CPU",
      "type": "row"
    },
    {
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
      "description": "Average CPU utilisation across all vCPUs. 100% = fully saturated (all cores).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never", "spanNulls": false },
          "decimals": 1, "max": 100, "min": 0, "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
        "type": "json", "source": "url", "format": "table",
        "url": "https://api.binarylane.com.au/v2/samplesets/${server_id}?data_interval=${interval}&start=${__from:date:iso}&end=${__to:date:iso}&per_page=200",
        "root_selector": "sample_sets",
        "columns": [
          { "selector": "period.end", "text": "Time", "type": "timestamp" },
          { "selector": "average.cpu_usage_percent", "text": "CPU %", "type": "number" }
        ],
        "url_options": { "method": "GET", "data": "" }, "parser": "backend", "filters": []
      }],
      "title": "CPU Usage %",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
      "description": "Memory used in bytes (avg) and peak MB per period. Requires mPanel Memory Graph agent installed on the server — see https://support.binarylane.com.au/support/solutions/articles/1000022811",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never", "spanNulls": false },
          "decimals": 0, "min": 0, "unit": "bytes",
          "noValue": "Agent not installed",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Peak MB" }, "properties": [{ "id": "unit", "value": "decmbytes" }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": { "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
          "type": "json", "source": "url", "format": "table",
          "url": "https://api.binarylane.com.au/v2/samplesets/${server_id}?data_interval=${interval}&start=${__from:date:iso}&end=${__to:date:iso}&per_page=200",
          "root_selector": "sample_sets",
          "columns": [
            { "selector": "period.end", "text": "Time", "type": "timestamp" },
            { "selector": "average.memory_usage_bytes", "text": "Avg Bytes", "type": "number" }
          ],
          "url_options": { "method": "GET", "data": "" }, "parser": "backend", "filters": []
        },
        {
          "refId": "B",
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
          "type": "json", "source": "url", "format": "table",
          "url": "https://api.binarylane.com.au/v2/samplesets/${server_id}?data_interval=${interval}&start=${__from:date:iso}&end=${__to:date:iso}&per_page=200",
          "root_selector": "sample_sets",
          "columns": [
            { "selector": "period.end", "text": "Time", "type": "timestamp" },
            { "selector": "maximum_memory_megabytes", "text": "Peak MB", "type": "number" }
          ],
          "url_options": { "method": "GET", "data": "" }, "parser": "backend", "filters": []
        }
      ],
      "title": "Memory Usage",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101, "title": "🌐 Network", "type": "row"
    },
    {
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
      "description": "Network throughput in kbps. Incoming = inbound to the server; Outgoing = outbound from the server.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never", "spanNulls": false },
          "decimals": 1, "min": 0, "unit": "kbits",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Incoming" }, "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Outgoing" }, "properties": [{ "id": "color", "value": { "fixedColor": "#F2CC0C", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
      "id": 3,
      "options": { "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
          "type": "json", "source": "url", "format": "table",
          "url": "https://api.binarylane.com.au/v2/samplesets/${server_id}?data_interval=${interval}&start=${__from:date:iso}&end=${__to:date:iso}&per_page=200",
          "root_selector": "sample_sets",
          "columns": [
            { "selector": "period.end", "text": "Time", "type": "timestamp" },
            { "selector": "average.network_incoming_kbps", "text": "Incoming", "type": "number" }
          ],
          "url_options": { "method": "GET", "data": "" }, "parser": "backend", "filters": []
        },
        {
          "refId": "B",
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
          "type": "json", "source": "url", "format": "table",
          "url": "https://api.binarylane.com.au/v2/samplesets/${server_id}?data_interval=${interval}&start=${__from:date:iso}&end=${__to:date:iso}&per_page=200",
          "root_selector": "sample_sets",
          "columns": [
            { "selector": "period.end", "text": "Time", "type": "timestamp" },
            { "selector": "average.network_outgoing_kbps", "text": "Outgoing", "type": "number" }
          ],
          "url_options": { "method": "GET", "data": "" }, "parser": "backend", "filters": []
        }
      ],
      "title": "Network Throughput (kbps)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102, "title": "💾 Storage I/O", "type": "row"
    },
    {
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
      "description": "Disk read/write throughput in kbps.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never", "spanNulls": false },
          "decimals": 1, "min": 0, "unit": "kbits",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Read" }, "properties": [{ "id": "color", "value": { "fixedColor": "#5794F2", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Write" }, "properties": [{ "id": "color", "value": { "fixedColor": "#FF9830", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 4,
      "options": { "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
          "type": "json", "source": "url", "format": "table",
          "url": "https://api.binarylane.com.au/v2/samplesets/${server_id}?data_interval=${interval}&start=${__from:date:iso}&end=${__to:date:iso}&per_page=200",
          "root_selector": "sample_sets",
          "columns": [
            { "selector": "period.end", "text": "Time", "type": "timestamp" },
            { "selector": "average.storage_read_kbps", "text": "Read", "type": "number" }
          ],
          "url_options": { "method": "GET", "data": "" }, "parser": "backend", "filters": []
        },
        {
          "refId": "B",
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
          "type": "json", "source": "url", "format": "table",
          "url": "https://api.binarylane.com.au/v2/samplesets/${server_id}?data_interval=${interval}&start=${__from:date:iso}&end=${__to:date:iso}&per_page=200",
          "root_selector": "sample_sets",
          "columns": [
            { "selector": "period.end", "text": "Time", "type": "timestamp" },
            { "selector": "average.storage_write_kbps", "text": "Write", "type": "number" }
          ],
          "url_options": { "method": "GET", "data": "" }, "parser": "backend", "filters": []
        }
      ],
      "title": "Storage Throughput (kbps)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
      "description": "Disk I/O operations per second — read and write IOPS.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never", "spanNulls": false },
          "decimals": 1, "min": 0, "unit": "reqps",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Read IOPS" }, "properties": [{ "id": "color", "value": { "fixedColor": "#5794F2", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Write IOPS" }, "properties": [{ "id": "color", "value": { "fixedColor": "#FF9830", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 5,
      "options": { "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
          "type": "json", "source": "url", "format": "table",
          "url": "https://api.binarylane.com.au/v2/samplesets/${server_id}?data_interval=${interval}&start=${__from:date:iso}&end=${__to:date:iso}&per_page=200",
          "root_selector": "sample_sets",
          "columns": [
            { "selector": "period.end", "text": "Time", "type": "timestamp" },
            { "selector": "average.storage_read_requests_per_second", "text": "Read IOPS", "type": "number" }
          ],
          "url_options": { "method": "GET", "data": "" }, "parser": "backend", "filters": []
        },
        {
          "refId": "B",
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
          "type": "json", "source": "url", "format": "table",
          "url": "https://api.binarylane.com.au/v2/samplesets/${server_id}?data_interval=${interval}&start=${__from:date:iso}&end=${__to:date:iso}&per_page=200",
          "root_selector": "sample_sets",
          "columns": [
            { "selector": "period.end", "text": "Time", "type": "timestamp" },
            { "selector": "average.storage_write_requests_per_second", "text": "Write IOPS", "type": "number" }
          ],
          "url_options": { "method": "GET", "data": "" }, "parser": "backend", "filters": []
        }
      ],
      "title": "Storage IOPS",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 103, "title": "📊 Data Transfer Quota", "type": "row"
    },
    {
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
      "description": "Monthly data transfer: used vs included quota. BinaryLane pools transfer across servers.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 1,
          "mappings": [],
          "max": 100, "min": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 75 }, { "color": "red", "value": 90 }] },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 28 },
      "id": 6,
      "options": { "minVizHeight": 75, "minVizWidth": 75, "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^Transfer Pct$/", "values": false }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
        "type": "json", "source": "url", "format": "table",
        "url": "https://api.binarylane.com.au/v2/data_usages/${server_id}/current",
        "root_selector": "data_usage",
        "json_options": { "root_is_not_array": true, "columnar": false },
        "columns": [
          { "selector": "current_transfer_usage_gigabytes", "text": "Used GB", "type": "number" },
          { "selector": "transfer_gigabytes", "text": "Quota GB", "type": "number" }
        ],
        "url_options": { "method": "GET", "data": "" }, "parser": "backend", "filters": []
      }],
      "transformations": [
        { "id": "calculateField", "options": { "alias": "Fraction", "mode": "binary", "binary": { "left": "Used GB", "operator": "/", "right": "Quota GB" } } },
        { "id": "calculateField", "options": { "alias": "Transfer Pct", "mode": "binary", "binary": { "left": "Fraction", "operator": "*", "right": "100" } } }
      ],
      "title": "Transfer Usage %",
      "type": "gauge"
    },
    {
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
      "description": "Raw transfer figures for the current billing period.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "decimals": 2, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }, "unit": "decgbytes" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Quota GB" }, "properties": [{ "id": "color", "value": { "fixedColor": "text", "mode": "fixed" } }, { "id": "displayName", "value": "Quota" }] },
          { "matcher": { "id": "byName", "options": "Used GB" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }, { "id": "displayName", "value": "Used" }] }
        ]
      },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 28 },
      "id": 7,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "vertical", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto", "wideLayout": true },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
        "type": "json", "source": "url", "format": "table",
        "url": "https://api.binarylane.com.au/v2/data_usages/${server_id}/current",
        "root_selector": "data_usage",
        "json_options": { "root_is_not_array": true, "columnar": false },
        "columns": [
          { "selector": "current_transfer_usage_gigabytes", "text": "Used GB", "type": "number" },
          { "selector": "transfer_gigabytes", "text": "Quota GB", "type": "number" }
        ],
        "url_options": { "method": "GET", "data": "" }, "parser": "backend", "filters": []
      }],
      "title": "Transfer: Used / Quota",
      "type": "stat"
    },
    {
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
      "description": "All servers in this account.",
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "filterable": true } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "status" }, "properties": [
            { "id": "mappings", "value": [
              { "type": "value", "options": { "active": { "color": "green", "index": 0, "text": "active" } } },
              { "type": "value", "options": { "new": { "color": "blue", "index": 1, "text": "new" } } },
              { "type": "value", "options": { "off": { "color": "yellow", "index": 2, "text": "off" } } },
              { "type": "value", "options": { "archive": { "color": "red", "index": 3, "text": "archive" } } }
            ]},
            { "id": "custom.cellOptions", "value": { "type": "color-background" } }
          ]}
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "id": 8,
      "options": { "cellHeight": "sm", "footer": { "show": false }, "showHeader": true, "sortBy": [{ "desc": false, "displayName": "name" }] },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
        "type": "json", "source": "url", "format": "table",
        "url": "https://api.binarylane.com.au/v2/servers?per_page=200",
        "root_selector": "servers",
        "columns": [
          { "selector": "id", "text": "ID", "type": "number" },
          { "selector": "name", "text": "Name", "type": "string" },
          { "selector": "status", "text": "Status", "type": "string" },
          { "selector": "region.slug", "text": "Region", "type": "string" },
          { "selector": "size_slug", "text": "Size", "type": "string" },
          { "selector": "networks.v4.0.ip_address", "text": "IPv4", "type": "string" }
        ],
        "url_options": { "method": "GET", "data": "" }, "parser": "backend", "filters": []
      }],
      "title": "All Servers",
      "type": "table"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["binarylane", "server", "performance"],
  "templating": {
    "list": [
      {
        "current": {}, "hide": 0, "includeAll": false, "label": "Datasource", "multi": false,
        "name": "DS_BINARYLANE", "query": "yesoreyeram-infinity-datasource", "refresh": 1, "type": "datasource"
      },
      {
        "current": {},
        "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
        "hide": 0, "includeAll": false, "label": "Server", "multi": false, "name": "server_id",
        "query": {
          "columns": [
            { "selector": "name", "text": "__text", "type": "string" },
            { "selector": "id", "text": "__value", "type": "string" }
          ],
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "${DS_BINARYLANE}" },
          "filters": [], "format": "table", "parser": "backend", "refId": "A",
          "root_selector": "servers", "source": "url", "type": "json",
          "url": "https://api.binarylane.com.au/v2/servers?per_page=200",
          "url_options": { "data": "", "method": "GET" }
        },
        "refresh": 1, "regex": "", "sort": 1, "type": "query"
      },
      {
        "current": { "selected": true, "text": "30 Minutes", "value": "half-hour" },
        "hide": 0, "includeAll": false, "label": "Resolution", "multi": false, "name": "interval",
        "options": [
          { "selected": false, "text": "5 Minutes",  "value": "five-minute" },
          { "selected": true,  "text": "30 Minutes", "value": "half-hour" },
          { "selected": false, "text": "4 Hours",    "value": "four-hour" },
          { "selected": false, "text": "1 Day",      "value": "day" },
          { "selected": false, "text": "1 Week",     "value": "week" }
        ],
        "query": "five-minute,half-hour,four-hour,day,week", "type": "custom"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "BinaryLane — Server Metrics",
  "uid": "bl-server-metrics",
  "version": 3
}
