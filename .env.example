# BinaryLane Grafana Stack — Environment Variables
# Copy this file to .env and fill in your values
# Usage: cp .env.example .env && nano .env

# Your BinaryLane API token
# Generate at: https://home.binarylane.com.au/api-info
# Required — docker-compose will refuse to start without this
BL_API_TOKEN=your-api-token-here

# Optional: override Grafana admin credentials (strongly recommended in production)
# GF_SECURITY_ADMIN_USER=admin
# GF_SECURITY_ADMIN_PASSWORD=changeme
